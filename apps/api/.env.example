# PostgreSQL (docker compose أو pnpm db:start)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/tender_dev"

# JWT
# في الإنتاج (NODE_ENV=production) يجب أن يكون سرًّا عشوائيًا لا يقل عن 16 حرفًا،
# وليس إحدى القيم الافتراضية المعروفة — وإلا يفشل الإقلاع (H0.1).
# توليد: `node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"`
JWT_SECRET="change-me-in-production"
JWT_EXPIRES_IN="7d"

# Server
PORT=4000
WEB_ORIGIN="http://localhost:5173"
# H0.2 — عدد قفزات البروكسي الموثوق أمام التطبيق (0 = لا بروكسي، 1 = بروكسي واحد/LB)
TRUST_PROXY=1
