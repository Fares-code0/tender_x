{
  "name": "tender-system",
  "private": true,
  "type": "module",
  "version": "0.1.0",
  "description": "نظام إدارة واكتشاف المناقصات الذكي — Brains Valley",
  "scripts": {
    "dev": "pnpm --parallel -r dev",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "lint": "eslint .",
    "format": "prettier --write .",
    "db:start": "pnpm --filter @tender/api db:start",
    "db:migrate": "pnpm --filter @tender/api db:migrate",
    "db:seed": "pnpm --filter @tender/api db:seed"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.19.0"
  },
  "engines": {
    "node": ">=20"
  }
}
